<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Production: structured JSON to stdout — parsed by log aggregators (Loki, ELK, CloudWatch) -->
    <springProfile name="prod">
        <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <!-- traceId/spanId are auto-injected by Micrometer Tracing via MDC -->
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <!-- Shorten logger names for smaller payloads -->
                <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
            </encoder>
        </appender>
        <root level="WARN">
            <appender-ref ref="JSON_STDOUT"/>
        </root>
        <logger name="com.example.service" level="INFO"/>
    </springProfile>

    <!-- Dev/test: human-readable with traceId for local debugging -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>%d{HH:mm:ss.SSS} [%thread] [%X{traceId:-no-trace}] %-5level %logger{36} - %msg%n</pattern>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.example.service" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
    </springProfile>
</configuration>
